generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum ParkingSpaceStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  DISABLED
}

model ParkingSpace {
  id           String             @id @default(uuid())
  ownerId      String
  name         String
  address      String
  reference    String
  latitude     Float
  longitude    Float
  pricePerHour Float
  openingTime  String
  closingTime  String
  status       ParkingSpaceStatus @default(AVAILABLE)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@map("parking_spaces")
}
