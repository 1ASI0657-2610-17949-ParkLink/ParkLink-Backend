generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum ReservationStatus {
  PENDING_PAYMENT
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}

model Reservation {
  id              String            @id @default(uuid())
  userId          String
  parkingSpaceId  String
  reservationCode String            @unique
  startTime       DateTime
  endTime         DateTime
  totalPrice      Float
  status          ReservationStatus @default(PENDING_PAYMENT)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([parkingSpaceId, startTime, endTime])
  @@map("reservations")
}
