{
  "version": 2,
  "installCommand": "cd ../.. && bun install",
  "buildCommand": "cd ../.. && bun run build:notification-service",
  "functions": {
    "src/main.ts": {
      "runtime": "@vercel/node@5.8.0"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/main.ts"
    }
  ]
}
