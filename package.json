{
  "name": "parklink-platform",
  "version": "1.0.0",
  "description": "ParkLink backend microservices monorepo built with NestJS, TypeScript, Prisma and Bun.",
  "private": true,
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.11",
    "node": ">=20.19.0 <21 || >=22.12.0 <23 || >=24.0.0"
  },
  "scripts": {
    "start:api-gateway": "nest start api-gateway --watch",
    "start:backend": "nest start backend --watch",
    "start:backend:dev": "nest start backend",
    "build:api-gateway": "nest build api-gateway",
    "build:backend": "bun run prisma:generate:backend && nest build backend",
    "prisma:generate:backend": "bunx prisma generate --config prisma.backend.config.ts",
    "prisma:migrate:deploy:backend": "bunx prisma migrate deploy --config prisma.backend.config.ts",
    "prisma:generate": "bun run prisma:generate:auth-service && bun run prisma:generate:users-service && bun run prisma:generate:parking-service && bun run prisma:generate:reservation-service && bun run prisma:generate:payment-service && bun run prisma:generate:notification-service",
    "prisma:generate:auth-service": "bunx prisma generate --config apps/auth-service/prisma.config.ts",
    "prisma:generate:users-service": "bunx prisma generate --config apps/users-service/prisma.config.ts",
    "prisma:generate:parking-service": "bunx prisma generate --config apps/parking-service/prisma.config.ts",
    "prisma:generate:reservation-service": "bunx prisma generate --config apps/reservation-service/prisma.config.ts",
    "prisma:generate:payment-service": "bunx prisma generate --config apps/payment-service/prisma.config.ts",
    "prisma:generate:notification-service": "bunx prisma generate --config apps/notification-service/prisma.config.ts",
    "test": "bun run prisma:generate && jest --passWithNoTests",
    "test:api-gateway": "jest --config api-gateway/test/jest.config.ts",
    "test:backend": "bun run prisma:generate:backend && jest --config apps/backend/test/jest.config.ts",
    "lint": "eslint \"{api-gateway,apps,libs}/**/*.ts\"",
    "format": "prettier --write \"{api-gateway,apps,libs}/**/*.ts\" \"*.json\" \"*.md\""
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mariadb": "^3.5.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.7.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vercel/node": "^5.8.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}